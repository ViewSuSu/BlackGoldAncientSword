<bases:UserControlBase
    x:Class="NarakaBladepoint.StatsAssistant.Modules.UI.Settings.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:bases="clr-namespace:NarakaBladepoint.StatsAssistant.Framework.Core.Bases.Views;assembly=NarakaBladepoint.StatsAssistant.Framework"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="400"
    d:DesignWidth="600"
    Background="WhiteSmoke"
    FontFamily="Segoe UI"
    mc:Ignorable="d">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,12"
            FontSize="18"
            FontWeight="SemiBold"
            Text="{DynamicResource Settings.Title}" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!--  Language  -->
                <GroupBox Style="{x:Null}" MinHeight="70">
                    <GroupBox.Header>
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="{DynamicResource Settings.Category.Language}" />
                    </GroupBox.Header>
                    <ItemsControl VerticalAlignment="Center" ItemsSource="{Binding LanguageOptions}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <RadioButton
                                    Margin="0,0,20,0"
                                    Padding="0"
                                    VerticalAlignment="Center"
                                    Command="{Binding DataContext.SelectLanguageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding Code}"
                                    Content="{Binding DisplayName}"
                                    GroupName="Language">
                                    <RadioButton.IsChecked>
                                        <MultiBinding Converter="{StaticResource EnumEqualityConverter}" Mode="OneWay">
                                            <Binding Path="Code" />
                                            <Binding Path="DataContext.SelectedLanguage" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                        </MultiBinding>
                                    </RadioButton.IsChecked>
                                </RadioButton>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </GroupBox>

                <!--  General  -->
                <GroupBox Margin="0,12,0,0" Style="{x:Null}">
                    <GroupBox.Header>
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="{DynamicResource Settings.Category.General}" />
                    </GroupBox.Header>
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                Grid.Column="0"
                                Height="28"
                                Text="{Binding DataPath, UpdateSourceTrigger=PropertyChanged}" />
                            <Button
                                Grid.Column="1"
                                Width="32"
                                Height="28"
                                Margin="4,0,0,0"
                                Command="{Binding BrowseFolderCommand}"
                                Content="..." />
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!--  Cache  -->
                <GroupBox Margin="0,12,0,0" Style="{x:Null}">
                    <GroupBox.Header>
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="{DynamicResource Settings.Category.Cache}" />
                    </GroupBox.Header>
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                Grid.Column="0"
                                Height="28"
                                Text="{Binding CachePath, UpdateSourceTrigger=PropertyChanged}" />
                            <Button
                                Grid.Column="1"
                                Width="32"
                                Height="28"
                                Margin="4,0,0,0"
                                Command="{Binding BrowseCacheFolderCommand}"
                                Content="..." />
                        </Grid>
                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                FontSize="12"
                                Foreground="Gray"
                                Text="{DynamicResource Settings.CacheSize}" />
                            <TextBlock
                                Grid.Column="1"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="12"
                                Text="{Binding CacheSizeText}" />
                            <Button
                                Grid.Column="2"
                                MinWidth="80"
                                Height="28"
                                Command="{Binding ClearCacheCommand}"
                                Content="{DynamicResource Settings.ClearCache}" />
                        </Grid>
                    </StackPanel>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>

        <StackPanel
            Grid.Row="2"
            Margin="0,16,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button MinWidth="80" Height="32" Margin="0,0,8,0" Command="{Binding SaveCommand}" Content="{DynamicResource Settings.Save}" />
        </StackPanel>
    </Grid>
</bases:UserControlBase>


