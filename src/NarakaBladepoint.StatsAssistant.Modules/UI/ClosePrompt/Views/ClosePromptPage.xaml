<bases:UserControlBase
    x:Class="NarakaBladepoint.StatsAssistant.Modules.UI.ClosePrompt.Views.ClosePromptPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:bases="clr-namespace:NarakaBladepoint.StatsAssistant.Framework.Core.Bases.Views;assembly=NarakaBladepoint.StatsAssistant.Framework"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    mc:Ignorable="d">
    <Grid
        x:Name="OverlayGrid"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        Background="#80000000"
        KeyDown="Grid_KeyDown"
        Focusable="True">
        <Border
            MaxWidth="945"
            Padding="10"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="White"
            CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  Title row with close button  -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        FontSize="16"
                        FontWeight="Bold"
                        Text="{DynamicResource ClosePrompt.Title}" />
                    <Button
                        Grid.Column="1"
                        Width="24"
                        Height="24"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="CloseButton_Click"
                        Cursor="Hand"
                        ToolTip="{DynamicResource TitleBar.Close}">
                        <Image
                            Width="15"
                            Height="15"
                            Source="/NarakaBladepoint.StatsAssistant.Resources;component/Images/close.png"
                            Stretch="Uniform" />
                    </Button>
                </Grid>

                <TextBlock
                    Grid.Row="1"
                    Margin="0,0,0,16"
                    FontSize="13"
                    Text="{DynamicResource ClosePrompt.Message}"
                    TextWrapping="Wrap" />

                <CheckBox
                    Grid.Row="2"
                    Margin="0,0,0,16"
                    Content="{DynamicResource ClosePrompt.RememberChoice}"
                    IsChecked="{Binding RememberChoice}" />

                <StackPanel
                    Grid.Row="3"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
                    <Button
                        MinWidth="100"
                        Height="32"
                        Margin="0,0,8,0"
                        Command="{Binding MinimizeToTaskbarCommand}" ToolTip="{DynamicResource ClosePrompt.MinimizeToTaskbar}" Content="{DynamicResource ClosePrompt.MinimizeToTaskbar}" />
                    <Button
                        MinWidth="80"
                        Height="32"
                        Command="{Binding ExitDirectlyCommand}" ToolTip="{DynamicResource ClosePrompt.ExitDirectly}" Content="{DynamicResource ClosePrompt.ExitDirectly}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</bases:UserControlBase>