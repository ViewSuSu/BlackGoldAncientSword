<bases:UserControlBase
    x:Class="NarakaBladepoint.StatsAssistant.Modules.UI.Announcement.Views.AnnouncementPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:bases="clr-namespace:NarakaBladepoint.StatsAssistant.Framework.Core.Bases.Views;assembly=NarakaBladepoint.StatsAssistant.Framework"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    mc:Ignorable="d">
    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#80000000">
        <Border
            MaxWidth="720"
            Padding="32"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="White"
            CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Margin="0,0,0,16"
                    FontSize="18"
                    FontWeight="Bold"
                    Text="{DynamicResource Nav.Announcement}" />

                <ScrollViewer Grid.Row="1" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,12"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="{DynamicResource Announcement.UpdateHistory}" />
                        <ItemsControl ItemsSource="{Binding UpdateHistory}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Grid.Column="0"
                                            VerticalAlignment="Top"
                                            FontSize="12"
                                            Foreground="Gray"
                                            Text="{Binding Version}" />
                                        <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                            <TextBlock
                                                FontSize="12"
                                                Text="{Binding Title}"
                                                TextWrapping="Wrap" />
                                            <TextBlock
                                                Margin="0,2,0,0"
                                                FontSize="11"
                                                Foreground="Gray"
                                                Text="{Binding Detail}"
                                                TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Separator Margin="0,12" />

                        <TextBlock
                            Margin="0,0,0,8"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="{DynamicResource Announcement.Notice}" />
                        <TextBlock
                            FontSize="12"
                            Foreground="Gray"
                            Text="{Binding Notice}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>

                <StackPanel
                    Grid.Row="2"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
                    <Button MinWidth="80" Height="32" Command="{Binding ConfirmCommand}" Content="{DynamicResource Announcement.Confirm}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</bases:UserControlBase>
