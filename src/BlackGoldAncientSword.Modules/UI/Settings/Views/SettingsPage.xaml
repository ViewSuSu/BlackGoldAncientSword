<bases:UserControlBase
    x:Class="BlackGoldAncientSword.Modules.UI.Settings.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:bases="clr-namespace:BlackGoldAncientSword.Framework.Core.Bases.Views;assembly=BlackGoldAncientSword.Framework"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    d:DesignHeight="400"
    d:DesignWidth="600"
    Background="WhiteSmoke"
    FontFamily="Segoe UI"
    mc:Ignorable="d">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,12"
            FontSize="18"
            FontWeight="SemiBold"
            Text="{DynamicResource Settings.Title}" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!--  Language  -->
                <GroupBox Style="{x:Null}" MinHeight="70" Padding="0,5,0,5">
                    <GroupBox.Header>
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="{DynamicResource Settings.Category.Language}" />
                    </GroupBox.Header>
                    <ItemsControl VerticalAlignment="Center" ItemsSource="{Binding LanguageOptions}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <RadioButton
                                    Margin="0,0,20,0"
                                    Padding="0"
                                    VerticalAlignment="Center"
                                    Command="{Binding DataContext.SelectLanguageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding Code}"
                                    Content="{Binding DisplayName}"
                                    GroupName="Language">
                                    <RadioButton.IsChecked>
                                        <MultiBinding Converter="{StaticResource EnumEqualityConverter}" Mode="OneWay">
                                            <Binding Path="Code" />
                                            <Binding Path="DataContext.SelectedLanguage" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                        </MultiBinding>
                                    </RadioButton.IsChecked>
                                </RadioButton>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </GroupBox>

                <!--  General  -->
                <GroupBox Margin="0,12,0,0" Style="{x:Null}" MinHeight="70" Padding="0,5,0,5">
                    <GroupBox.Header>
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="{DynamicResource Settings.Category.General}" />
                    </GroupBox.Header>
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                Grid.Column="0"
                                Height="28"
                                Text="{Binding DataPath, UpdateSourceTrigger=LostFocus}" />
                            <Button
                                Grid.Column="1"
                                Width="32"
                                Height="28"
                                Margin="4,0,0,0"
                                Command="{Binding BrowseFolderCommand}"
                                Content="..." ToolTip="{DynamicResource Settings.BrowseDataPath}" />
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!--  Cache  -->
                <GroupBox Margin="0,12,0,0" Style="{x:Null}" MinHeight="70" Padding="0,5,0,5">
                    <GroupBox.Header>
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="{DynamicResource Settings.Category.Cache}" />
                    </GroupBox.Header>
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                Grid.Column="0"
                                Height="28"
                                Text="{Binding CachePath, UpdateSourceTrigger=LostFocus}" />
                            <Button
                                Grid.Column="1"
                                Width="32"
                                Height="28"
                                Margin="4,0,0,0"
                                Command="{Binding BrowseCacheFolderCommand}"
                                Content="..." ToolTip="{DynamicResource Settings.BrowseCachePath}" />
                        </Grid>
                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                FontSize="12"
                                Foreground="Gray"
                                Text="{DynamicResource Settings.CacheSize}" />
                            <TextBlock
                                Grid.Column="1"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="12"
                                Text="{Binding CacheSizeText}" />
                            <Button
                                Grid.Column="2"
                                MinWidth="80"
                                Height="28"
                                Command="{Binding ClearCacheCommand}" ToolTip="{DynamicResource Settings.ClearCache}" Content="{DynamicResource Settings.ClearCache}" />
                        </Grid>
                    </StackPanel>
                </GroupBox>



                <!--  更新  -->
                <GroupBox Margin="0,12,0,0" Style="{x:Null}" MinHeight="70" Padding="0,5,0,5">
                    <GroupBox.Header>
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="{DynamicResource Settings.AutoUpdate}" />
                    </GroupBox.Header>
                    <StackPanel Orientation="Horizontal">
                        <ToggleButton
                            Width="44"
                            Height="22"
                            Padding="0"
                            VerticalAlignment="Center"
                            IsChecked="{Binding AutoCheckUpdates}"
                            ToolTip="{DynamicResource Settings.AutoCheckUpdates}">
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border
                                                    x:Name="Border"
                                                    Width="44"
                                                    Height="22"
                                                    Background="#CCCCCC"
                                                    CornerRadius="11">
                                                    <Ellipse
                                                        x:Name="Thumb"
                                                        Width="18"
                                                        Height="18"
                                                        Margin="2,0,0,0"
                                                        HorizontalAlignment="Left"
                                                        Fill="White" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Border" Property="Background" Value="#4CAF50" />
                                                        <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                                                        <Setter TargetName="Thumb" Property="Margin" Value="0,0,2,0" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ToggleButton.Style>
                        </ToggleButton>
                        <TextBlock
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="13"
                            Text="{DynamicResource Settings.AutoCheckUpdates}" />
                    </StackPanel>
                </GroupBox>
                <!--  Close Behavior  -->
                <GroupBox Margin="0,12,0,0" Style="{x:Null}" MinHeight="70" Padding="0,5,0,5">
                    <GroupBox.Header>
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="{DynamicResource Settings.Category.CloseBehavior}" />
                    </GroupBox.Header>
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,8"
                            FontSize="12"
                            Foreground="Gray"
                            Text="{DynamicResource Settings.CloseBehavior.Description}" />
                        <ItemsControl VerticalAlignment="Center" ItemsSource="{Binding CloseBehaviorOptions}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <RadioButton
                                        Margin="0,0,20,0"
                                        Padding="0"
                                        VerticalAlignment="Center"
                                        Command="{Binding DataContext.SelectCloseBehaviorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding Value}"
                                        Content="{Binding DisplayName}"
                                        GroupName="CloseBehavior">
                                        <RadioButton.IsChecked>
                                            <MultiBinding Converter="{StaticResource EnumEqualityConverter}" Mode="OneWay">
                                                <Binding Path="Value" />
                                                <Binding Path="DataContext.SelectedCloseBehavior" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                            </MultiBinding>
                                        </RadioButton.IsChecked>
                                    </RadioButton>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <CheckBox
                            Margin="0,12,0,8"
                            Content="{DynamicResource Settings.CloseBehavior.RememberChoice}"
                            IsChecked="{Binding RememberCloseBehavior}" />
                    </StackPanel>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</bases:UserControlBase>


