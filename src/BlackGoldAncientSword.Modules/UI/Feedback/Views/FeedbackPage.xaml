<UserControl
    x:Class="BlackGoldAncientSword.Modules.UI.Feedback.Views.FeedbackPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:bases="clr-namespace:BlackGoldAncientSword.Framework.Core.Bases.Views;assembly=BlackGoldAncientSword.Framework"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    Background="Transparent"
    mc:Ignorable="d">
    <Grid
        x:Name="OverlayGrid"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        Background="#80000000"
        KeyDown="Grid_KeyDown"
        Focusable="True">
        <Border
            MaxWidth="500"
            Padding="20"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="White"
            CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Title row with close button -->
                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        FontSize="18"
                        FontWeight="Bold"
                        Text="问题反馈" />
                    <Button
                        Grid.Column="1"
                        Width="24"
                        Height="24"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="{DynamicResource TitleBar.Close}">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="Click">
                                <i:InvokeCommandAction Command="{Binding DismissCommand}" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                        <Image
                            Width="15"
                            Height="15"
                            Source="/BlackGoldAncientSword.Resources;component/Images/close.png"
                            Stretch="Uniform" />
                    </Button>
                </Grid>

                <ScrollViewer Grid.Row="1" Margin="0,0,0,16" MaxHeight="400">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,8"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="客户端问题反馈群" />
                        <TextBox
                            Margin="0,0,0,16"
                            Padding="0"
                            Background="Transparent"
                            BorderThickness="0"
                            FontSize="12"
                            Foreground="Gray"
                            IsReadOnly="True"
                            Text="①群：146088141" />

                        <TextBlock
                            Margin="0,0,0,8"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="数据问题反馈群" />
                        <TextBlock
                            Margin="0,0,0,4"
                            FontSize="12"
                            Foreground="Gray"
                            Text="QQ群机器人也可以查战绩"
                            TextWrapping="Wrap" />
                        <TextBox
                            Margin="0,0,0,4"
                            Padding="0"
                            Background="Transparent"
                            BorderThickness="0"
                            FontSize="12"
                            Foreground="Gray"
                            IsReadOnly="True"
                            Text="①群：476074617" />
                        <TextBox
                            Margin="0,0,0,4"
                            Padding="0"
                            Background="Transparent"
                            BorderThickness="0"
                            FontSize="12"
                            Foreground="Gray"
                            IsReadOnly="True"
                            Text="②群：649891198" />
                        <TextBox
                            Margin="0,0,0,4"
                            Padding="0"
                            Background="Transparent"
                            BorderThickness="0"
                            FontSize="12"
                            Foreground="Gray"
                            IsReadOnly="True"
                            Text="③群：966720321" />
                        <TextBlock
                            Margin="0,0,0,16"
                            FontSize="11"
                            Foreground="#999999"
                            Text="QQ等级超过32（两个太阳）的自动审核进群，小号不给进"
                            TextWrapping="Wrap" />

                        <Separator Margin="0,8" />

                        <TextBlock
                            Margin="0,0,0,4"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="网页端" />
                        <TextBlock Margin="0,0,0,12" FontSize="12">
                            <Hyperlink
                                Cursor="Hand"
                                Foreground="#4A90D9"
                                NavigateUri="https://naraka.drivod.top/"
                                RequestNavigate="Hyperlink_RequestNavigate">
                                https://naraka.drivod.top/
                            </Hyperlink>
                        </TextBlock>

                        <TextBlock
                            Margin="0,0,0,4"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Text="GitHub" />
                        <TextBlock FontSize="12">
                            <Hyperlink
                                Cursor="Hand"
                                Foreground="#4A90D9"
                                NavigateUri="https://github.com/ViewSuSu/BlackGoldAncientSword"
                                RequestNavigate="Hyperlink_RequestNavigate">
                                https://github.com/ViewSuSu/BlackGoldAncientSword
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel
                    Grid.Row="2"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
                    <Button MinWidth="80" Height="32" Content="关闭">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="Click">
                                <i:InvokeCommandAction Command="{Binding ConfirmCommand}" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
