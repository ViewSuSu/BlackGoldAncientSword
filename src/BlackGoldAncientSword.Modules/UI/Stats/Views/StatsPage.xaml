<bases:UserControlBase
    x:Class="BlackGoldAncientSword.Modules.UI.Stats.Views.StatsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:bases="clr-namespace:BlackGoldAncientSword.Framework.Core.Bases.Views;assembly=BlackGoldAncientSword.Framework"
    xmlns:controls="clr-namespace:BlackGoldAncientSword.Framework.UI.Controls;assembly=BlackGoldAncientSword.Framework"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="clr-namespace:HandyControl.Controls;assembly=HandyControl"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="clr-namespace:BlackGoldAncientSword.Modules.UI.Stats.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewmodels:StatsPageViewModel}"
    d:DesignHeight="600"
    d:DesignWidth="800"
    FontFamily="Segoe UI"
    mc:Ignorable="d">

    <Grid>
        <Grid Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>


            <!--  === TOOLBAR: Search + Actions ===  -->
            <Grid Grid.Row="0" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <hc:SearchBar
                    Height="25"
                    VerticalAlignment="Center"
                    hc:InfoElement.Placeholder="{DynamicResource Search.Input}"
                    hc:TitleElement.Title="{DynamicResource Search.Title}"
                    hc:TitleElement.TitlePlacement="Left"
                    Command="{Binding SearchCommand}"
                    Style="{StaticResource SearchBarExtend}"
                    Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

                <!--  Action buttons (right)  -->
                <StackPanel
                    Grid.Column="2"
                    Margin="10,0,0,0"
                    Orientation="Horizontal">
                    <!--  Refresh button  -->
                    <Button
                        Width="28"
                        Height="28"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding RefreshAllCommand}"
                        Cursor="Hand"
                        ToolTip="{DynamicResource Stats.Refresh}">
                        <Image
                            Width="16"
                            Height="16"
                            Source="pack://application:,,,/BlackGoldAncientSword.Resources;component/Images/refresh_data.png" />
                    </Button>

                    <!--  Back to me button (hidden when viewing local user)  -->
                    <Button
                        Width="28"
                        Height="28"
                        Margin="6,0,0,0"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding GoBackToMeCommand}"
                        Cursor="Hand"
                        ToolTip="{DynamicResource Stats.BackToMe}" ToolTipService.ShowOnDisabled="True">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="IsEnabled" Value="True" />
                                <Setter Property="Opacity" Value="1" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLocalUser}" Value="True">
                                        <Setter Property="IsEnabled" Value="False" />
                                        <Setter Property="Opacity" Value="0.5" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Image
                            Width="16"
                            Height="16"
                            Source="pack://application:,,,/BlackGoldAncientSword.Resources;component/Images/back_to_me.png" />
                    </Button>
                </StackPanel>
            </Grid>

            <!--  === NOT FOUND OVERLAY ===  -->
            <Border
                Grid.Row="1"
                Grid.RowSpan="4"
                Background="White"
                Visibility="{Binding ShowNotFound, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="18"
                    Foreground="Gray"
                    Text="{DynamicResource Stats.UserNotFound}" />
            </Border>

            <!--  === TOP: Player Info + Filters ===  -->
            <Grid Grid.Row="1">
                <StackPanel>
                    <StackPanel Margin="0,5,0,5">
                        <!--  Avatar - centered  -->
                        <Border
                            Width="48"
                            Height="48"
                            HorizontalAlignment="Center"
                            BorderBrush="LightGray"
                            BorderThickness="1"
                            ClipToBounds="True"
                            CornerRadius="5">
                            <Image
                                Width="48"
                                Height="48"
                                Source="{Binding AvatarUrl, IsAsync=True, Converter={StaticResource UrlToImageSourceConverter}}"
                                Stretch="UniformToFill" />
                        </Border>

                        <!--  Level + Name - centered below avatar  -->
                        <StackPanel
                            Margin="0,4,0,0"
                            HorizontalAlignment="Center"
                            Orientation="Horizontal">
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="11"
                                Foreground="Gray"
                                Text="{Binding Level}" />
                            <TextBlock
                                Margin="6,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="16"
                                FontWeight="Bold"
                                Text="{Binding UserName}" />
                            <Button
                                Width="20"
                                Height="20"
                                Margin="10,0,0,0"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                ToolTip="{DynamicResource Stats.CopyNickname}">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="Click">
                                        <i:InvokeCommandAction Command="{Binding CopyUserNameCommand}" />
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                                <Path
                                    Width="12"
                                    Height="12"
                                    Data="M16 1H4C2.9 1 2 1.9 2 3V17H4V3H16V1ZM19 5H8C6.9 5 6 5.9 6 7V21C6 22.1 6.9 23 8 23H19C20.1 23 21 22.1 21 21V7C21 5.9 20.1 5 19 5ZM19 21H8V7H19V21Z"
                                    Fill="#999999"
                                    Stretch="Uniform" />
                            </Button>
                        </StackPanel>

                        <!--  UID - centered at bottom  -->
                        <StackPanel
                            Margin="0,2,0,0"
                            HorizontalAlignment="Center"
                            Orientation="Horizontal">
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="12"
                                Foreground="Gray">
                                <Run Text="UID: " /><Run Text="{Binding UID}" />
                            </TextBlock>
                            <Button
                                Width="16"
                                Height="16"
                                Margin="10,0,0,0"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                ToolTip="{DynamicResource Stats.CopyUID}">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="Click">
                                        <i:InvokeCommandAction Command="{Binding CopyUIDCommand}" />
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                                <Path
                                    Width="10"
                                    Height="10"
                                    Data="M16 1H4C2.9 1 2 1.9 2 3V17H4V3H16V1ZM19 5H8C6.9 5 6 5.9 6 7V21C6 22.1 6.9 23 8 23H19C20.1 23 21 22.1 21 21V7C21 5.9 20.1 5 19 5ZM19 21H8V7H19V21Z"
                                    Fill="#999999"
                                    Stretch="Uniform" />
                            </Button>
                        </StackPanel>
                    </StackPanel>

                </StackPanel>

                <!--  unified loading overlay (on top)  -->
                <Border
                    d:Visibility="Hidden"
                    Background="White"
                    Visibility="{Binding IsPlayerInfoLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <hc:CircleProgressBar
                        Width="64"
                        Height="64"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        ArcThickness="4"
                        Foreground="#4A90D9"
                        IsIndeterminate="True" />
                </Border>
            </Grid>



            <!--  === FILTERS + DETAIL STATS in rounded container ===  -->
            <Border
                Grid.Row="2"
                Margin="0,8,0,0"
                Padding="10"
                BorderBrush="LightGray"
                BorderThickness="1"
                CornerRadius="5">
                <StackPanel>

                    <!--  === FILTERS ===  -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!--  Season (left)  -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                FontSize="13"
                                Text="{DynamicResource Stats.Season}" />
                            <ComboBox
                                Width="160"
                                Height="28"
                                DisplayMemberPath="Name"
                                ItemsSource="{Binding Seasons}"
                                SelectedItem="{Binding SelectedSeason}" />
                        </StackPanel>

                        <!--  Team Size RadioButtons via ItemsControl  -->
                        <ItemsControl
                            Grid.Column="1"
                            Margin="20,0,0,0"
                            ItemsSource="{Binding TeamSizes}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <RadioButton
                                        Margin="0,0,12,0"
                                        CommandParameter="{Binding .}"
                                        Content="{Binding DisplayName}"
                                        GroupName="TeamSize">
                                        <i:Interaction.Triggers>
                                            <i:EventTrigger EventName="Click">
                                                <i:InvokeCommandAction Command="{Binding DataContext.SelectTeamSizeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding .}" />
                                            </i:EventTrigger>
                                        </i:Interaction.Triggers>
                                        <RadioButton.IsChecked>
                                            <MultiBinding Converter="{StaticResource EnumEqualityConverter}" Mode="OneWay">
                                                <Binding Path="Value" />
                                                <Binding Path="DataContext.SelectedTeamSize" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                            </MultiBinding>
                                        </RadioButton.IsChecked>
                                    </RadioButton>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!--  Category RadioButtons via ItemsControl (right)  -->
                        <ItemsControl Grid.Column="3" ItemsSource="{Binding Categories}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <RadioButton
                                        Margin="0,0,12,0"
                                        CommandParameter="{Binding .}"
                                        Content="{Binding DisplayName}"
                                        GroupName="Category">
                                        <i:Interaction.Triggers>
                                            <i:EventTrigger EventName="Click">
                                                <i:InvokeCommandAction Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding .}" />
                                            </i:EventTrigger>
                                        </i:Interaction.Triggers>
                                        <RadioButton.IsChecked>
                                            <MultiBinding Converter="{StaticResource EnumEqualityConverter}" Mode="OneWay">
                                                <Binding Path="Value" />
                                                <Binding Path="DataContext.SelectedCategory" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                            </MultiBinding>
                                        </RadioButton.IsChecked>
                                    </RadioButton>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>


                    <!--  === DETAIL STATS ===  -->
                    <TextBlock
                        Margin="0,0,0,8"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Text="{DynamicResource Stats.DetailTitle}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!--  Rank (left column)  -->
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <Border
                                Width="100"
                                Height="100"
                                BorderBrush="LightGray"
                                BorderThickness="1"
                                ClipToBounds="True"
                                CornerRadius="5">
                                <Image
                                    Width="100"
                                    Height="100"
                                    Source="{Binding RankIcon, IsAsync=True, Converter={StaticResource UrlToImageSourceConverter}}"
                                    Stretch="Uniform" />
                            </Border>
                            <StackPanel
                                Margin="0,6,0,0"
                                HorizontalAlignment="Center"
                                Orientation="Horizontal">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Text="{Binding PageRankName}" />
                                <Image
                                    Width="16"
                                    Height="16"
                                    Margin="2,0,0,0"
                                    VerticalAlignment="Center"
                                    Source="pack://application:,,,/BlackGoldAncientSword.Resources;component/Images/star_icon.png"
                                    Visibility="{Binding PageHasStars, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Text="{Binding PageStarCount}"
                                    Visibility="{Binding PageHasStars, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </StackPanel>
                            <TextBlock
                                Margin="0,2,0,0"
                                HorizontalAlignment="Center"
                                FontSize="13"
                                Foreground="Gray">
                                <Run Text="{Binding RankTierScore, StringFormat='{}{0}'}" /><Run Text="{DynamicResource Stats.Points}" />
                            </TextBlock>
                        </StackPanel>

                        <!--  Detail stats (right column)  -->
                        <ItemsControl Grid.Column="1" ItemsSource="{Binding DetailStats}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="4" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Margin="3,0,3,6"
                                        Padding="10,0"
                                        BorderBrush="Gray"
                                        BorderThickness="0.2"
                                        CornerRadius="5">
                                        <DockPanel>
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                DockPanel.Dock="Right"
                                                FontSize="14"
                                                FontWeight="Bold"
                                                Text="{Binding Value}" />
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="11"
                                                Foreground="Gray"
                                                Text="{Binding Label}" />
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!--  Stats loading overlay  -->
                        <Border
                            Grid.ColumnSpan="2"
                            d:Visibility="Hidden"
                            Background="White"
                            Visibility="{Binding IsStatsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <hc:CircleProgressBar
                                Width="64"
                                Height="64"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                ArcThickness="4"
                                Foreground="#4A90D9"
                                IsIndeterminate="True" />
                        </Border>
                    </Grid>

                </StackPanel>
            </Border>


            <TextBlock
                Grid.Row="3"
                Margin="0,20,0,8"
                FontSize="15"
                FontWeight="SemiBold"
                Text="{DynamicResource Stats.RecentBattles}" />
            <Grid Grid.Row="4">
                <DataGrid
                    d:ItemsSource="{d:SampleData}"
                    AutoGenerateColumns="False"
                    CanUserSortColumns="False"
                    GridLinesVisibility="None"
                    HeadersVisibility="Column"
                    IsReadOnly="True"
                    ItemsSource="{Binding RecentBattles}"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <DataGrid.ColumnHeaderStyle>
                        <Style BasedOn="{StaticResource DataGridColumnHeaderStyle}" TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                            <Setter Property="Background" Value="#F2F3F5" />
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style BasedOn="{StaticResource DataGridCellStyle}" TargetType="DataGridCell">
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Background" Value="Transparent" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.RowStyle>
                        <Style BasedOn="{StaticResource DataGridRowStyle}" TargetType="DataGridRow">
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#DAE8F7" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="50">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="{DynamicResource Stats.Header.Rank}" TextTrimming="CharacterEllipsis">
                                    <TextBlock.ToolTip>
                                        <ToolTip>
                                            <TextBlock Text="{DynamicResource Stats.Header.Rank}" />
                                        </ToolTip>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        Foreground="Gray"
                                        Text="{Binding Rank}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Width="*" Header="">

                            <DataGridTemplateColumn.CellStyle>
                                <Style BasedOn="{StaticResource DataGridCellStyle}" TargetType="DataGridCell">
                                    <Setter Property="HorizontalContentAlignment" Value="Left" />
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="BorderThickness" Value="0" />
                                            <Setter Property="Background" Value="Transparent" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTemplateColumn.CellStyle>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid MinWidth="180" HorizontalAlignment="Stretch">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="28" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Image
                                            Grid.Column="0"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Source="{Binding HeroIcon, IsAsync=True, Converter={StaticResource UrlToImageSourceConverter}}"
                                            Stretch="Uniform" />
                                        <ItemsControl
                                            Grid.Column="1"
                                            Margin="4,0,0,0"
                                            VerticalAlignment="Center"
                                            d:ItemsSource="{d:SampleData}"
                                            ItemsSource="{Binding HonorTitles}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <controls:DataGridWrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Image
                                                        Width="28"
                                                        Height="28"
                                                        Margin="0"
                                                        VerticalAlignment="Center"
                                                        Source="{Binding Icon, IsAsync=True, Converter={StaticResource UrlToImageSourceConverter}}"
                                                        Stretch="Uniform">
                                                        <Image.ToolTip>
                                                            <ToolTip>
                                                                <StackPanel>
                                                                    <TextBlock FontWeight="Bold" Text="{Binding HonorName}" />
                                                                    <TextBlock Text="{Binding HonorDesc}" />
                                                                </StackPanel>
                                                            </ToolTip>
                                                        </Image.ToolTip>
                                                    </Image>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Width="75">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="{DynamicResource Stats.Header.ModeCategory}" TextTrimming="CharacterEllipsis">
                                    <TextBlock.ToolTip>
                                        <ToolTip>
                                            <TextBlock Text="{DynamicResource Stats.Header.ModeCategory}" />
                                        </ToolTip>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        Foreground="Gray"
                                        Text="{Binding GameModeCategoryText}"
                                        TextAlignment="Center" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Width="75">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="{DynamicResource Stats.Header.ModeType}" TextTrimming="CharacterEllipsis">
                                    <TextBlock.ToolTip>
                                        <ToolTip>
                                            <TextBlock Text="{DynamicResource Stats.Header.ModeType}" />
                                        </ToolTip>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        Foreground="Gray"
                                        Text="{Binding GameModeTeamSizeText}"
                                        TextAlignment="Center" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Width="50">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="{DynamicResource Stats.Header.Kill}" TextTrimming="CharacterEllipsis">
                                    <TextBlock.ToolTip>
                                        <ToolTip>
                                            <TextBlock Text="{DynamicResource Stats.Header.Kill}" />
                                        </ToolTip>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontWeight="SemiBold"
                                        Foreground="#333333"
                                        Text="{Binding Kill}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Width="65">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="{DynamicResource Stats.Header.Damage}" TextTrimming="CharacterEllipsis">
                                    <TextBlock.ToolTip>
                                        <ToolTip>
                                            <TextBlock Text="{DynamicResource Stats.Header.Damage}" />
                                        </ToolTip>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        Foreground="#333333"
                                        Text="{Binding Damage}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Width="140">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="{DynamicResource Stats.Header.RankScore}" TextTrimming="CharacterEllipsis">
                                    <TextBlock.ToolTip>
                                        <ToolTip>
                                            <TextBlock Text="{DynamicResource Stats.Header.RankScore}" />
                                        </ToolTip>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Foreground="#333333"
                                            Text="{Binding RankDisplayText}" />
                                        <Image
                                            Width="14"
                                            Height="14"
                                            Margin="2,0,0,0"
                                            VerticalAlignment="Center"
                                            Source="pack://application:,,,/BlackGoldAncientSword.Resources;component/Images/star_icon.png"
                                            Visibility="{Binding HasStars, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Foreground="#333333"
                                            Text="{Binding StarCount}"
                                            Visibility="{Binding HasStars, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <TextBlock
                                            Margin="3,0,0,0"
                                            VerticalAlignment="Center"
                                            FontSize="10"
                                            Foreground="Gray"
                                            Text="{Binding ScoreNumber}"
                                            Visibility="{Binding HasStars, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <TextBlock
                                            Margin="6,0,0,0"
                                            VerticalAlignment="Center"
                                            FontSize="11"
                                            Foreground="{Binding ScoreDiff, Converter={StaticResource ScoreDiffToColorConverter}}"
                                            Text="{Binding ScoreDiffDisplay}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Width="130">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="{DynamicResource Stats.Header.Time}" TextTrimming="CharacterEllipsis">
                                    <TextBlock.ToolTip>
                                        <ToolTip>
                                            <TextBlock Text="{DynamicResource Stats.Header.Time}" />
                                        </ToolTip>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="11"
                                        Foreground="Gray"
                                        Text="{Binding BattleTime}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!--  Recent battles loading overlay  -->
                <Border
                    d:Visibility="Hidden"
                    Background="White"
                    Visibility="{Binding IsRecentBattlesLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <hc:CircleProgressBar
                        Width="64"
                        Height="64"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        ArcThickness="4"
                        Foreground="#4A90D9"
                        IsIndeterminate="True" />
                </Border>
            </Grid>
        </Grid>
    </Grid>
</bases:UserControlBase>

