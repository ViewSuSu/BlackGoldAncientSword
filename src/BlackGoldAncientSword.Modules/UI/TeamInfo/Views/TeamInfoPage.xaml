<bases:UserControlBase
    x:Class="BlackGoldAncientSword.Modules.UI.TeamInfo.Views.TeamInfoPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:bases="clr-namespace:BlackGoldAncientSword.Framework.Core.Bases.Views;assembly=BlackGoldAncientSword.Framework"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="clr-namespace:BlackGoldAncientSword.Modules.UI.TeamInfo.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewmodels:TeamInfoPageViewModel}"
    FontFamily="Segoe UI"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Status text -->
        <TextBlock
            Grid.Row="0"
            Margin="0,5,0,10"
            HorizontalAlignment="Center"
            FontSize="13"
            Foreground="Gray"
            Text="{Binding StatusText}" />

        <!-- Team members list -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl
                Margin="10,0"
                ItemsSource="{Binding TeamMembers}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid
                            MinHeight="80"
                            Margin="0,0,0,15"
                            Background="White">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Avatar -->
                            <Border
                                Grid.Row="0"
                                Grid.RowSpan="3"
                                Width="48"
                                Height="48"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                BorderBrush="LightGray"
                                BorderThickness="1"
                                ClipToBounds="True"
                                CornerRadius="5">
                                <Image
                                    Width="48"
                                    Height="48"
                                    Source="{Binding AvatarUrl, IsAsync=True, Converter={StaticResource UrlToImageSourceConverter}}"
                                    Stretch="UniformToFill" />
                            </Border>

                            <!-- Name + Level -->
                            <StackPanel
                                Grid.Row="0"
                                Grid.Column="1"
                                Orientation="Horizontal">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="11"
                                    Foreground="Gray"
                                    Text="{Binding Level}" />
                                <TextBlock
                                    Margin="6,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Text="{Binding UserName}" />
                            </StackPanel>

                            <!-- UID -->
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="1"
                                Margin="0,2,0,0"
                                FontSize="12"
                                Foreground="Gray">
                                <Run Text="UID: " /><Run Text="{Binding UID}" />
                            </TextBlock>

                            <!-- Loading / Status -->
                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="1"
                                Margin="0,4,0,0"
                                FontSize="12"
                                Foreground="#E74C3C"
                                Text="{Binding StatusText}"
                                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</bases:UserControlBase>
