<bases:UserControlBase
    x:Class="BlackGoldAncientSword.Modules.UI.TeamInfo.Views.TeamInfoPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:bases="clr-namespace:BlackGoldAncientSword.Framework.Core.Bases.Views;assembly=BlackGoldAncientSword.Framework"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="clr-namespace:HandyControl.Controls;assembly=HandyControl"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="clr-namespace:BlackGoldAncientSword.Modules.UI.TeamInfo.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewmodels:TeamInfoPageViewModel}"
    d:DesignHeight="700"
    d:DesignWidth="1100"
    FontFamily="Segoe UI"
    mc:Ignorable="d">
    <Grid>
        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" MinHeight="28" />
                </Grid.RowDefinitions>
                <Border
                    Grid.Row="0"
                    Margin="10,0,10,8"
                    Padding="10,8"
                    BorderBrush="LightGray"
                    BorderThickness="1"
                    CornerRadius="5"
                    Visibility="{Binding HasMember0, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                FontSize="13"
                                Text="{DynamicResource Stats.Season}"
                                TextTrimming="CharacterEllipsis" />
                            <ComboBox
                                Width="160"
                                Height="28"
                                DisplayMemberPath="Name"
                                ItemsSource="{Binding Seasons}"
                                SelectedItem="{Binding SelectedSeason}" />
                        </StackPanel>
                        <ItemsControl
                            Grid.Column="1"
                            Margin="20,0,0,0"
                            ItemsSource="{Binding TeamSizes}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <RadioButton
                                        Margin="0,0,12,0"
                                        CommandParameter="{Binding .}"
                                        Content="{Binding DisplayName}"
                                        GroupName="TeamSize">
                                        <i:Interaction.Triggers>
                                            <i:EventTrigger EventName="Click">
                                                <i:InvokeCommandAction Command="{Binding DataContext.SelectTeamSizeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding .}" />
                                            </i:EventTrigger>
                                        </i:Interaction.Triggers>
                                        <RadioButton.IsChecked>
                                            <MultiBinding Converter="{StaticResource EnumEqualityConverter}" Mode="OneWay">
                                                <Binding Path="Value" />
                                                <Binding Path="DataContext.SelectedTeamSize" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                            </MultiBinding>
                                        </RadioButton.IsChecked>
                                    </RadioButton>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <ItemsControl Grid.Column="3" ItemsSource="{Binding Categories}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <RadioButton
                                        Margin="0,0,12,0"
                                        CommandParameter="{Binding .}"
                                        Content="{Binding DisplayName}"
                                        GroupName="Category">
                                        <i:Interaction.Triggers>
                                            <i:EventTrigger EventName="Click">
                                                <i:InvokeCommandAction Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding .}" />
                                            </i:EventTrigger>
                                        </i:Interaction.Triggers>
                                        <RadioButton.IsChecked>
                                            <MultiBinding Converter="{StaticResource EnumEqualityConverter}" Mode="OneWay">
                                                <Binding Path="Value" />
                                                <Binding Path="DataContext.SelectedCategory" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                            </MultiBinding>
                                        </RadioButton.IsChecked>
                                    </RadioButton>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Refresh button - only enabled during hero selection -->
                        <Button
                            Grid.Column="4"
                            Width="28"
                            Height="28"
                            Margin="6,0,0,0"
                            Padding="0"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            Command="{Binding RefreshOcrCommand}"
                            Cursor="Hand"
                            ToolTip="{DynamicResource TeamInfo.RefreshOcr}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="IsEnabled" Value="True" />
                                    <Setter Property="Opacity" Value="1" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsHeroSelectionPhase}" Value="False">
                                            <Setter Property="IsEnabled" Value="False" />
                                            <Setter Property="Opacity" Value="0.5" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Image
                                Width="16"
                                Height="16"
                                Source="pack://application:,,,/BlackGoldAncientSword.Resources;component/Images/refresh_data.png" />
                        </Button>
                    </Grid>
                </Border>

                <Grid
                    x:Name="MainContentGrid"
                    Grid.Row="2"
                    Margin="10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" MinHeight="28" />
                        <RowDefinition Height="Auto" MinHeight="28" />
                        <RowDefinition Height="Auto" MinHeight="28" />
                        <RowDefinition Height="Auto" MinHeight="28" />
                        <RowDefinition Height="Auto" MinHeight="28" />
                        <RowDefinition Height="Auto" MinHeight="28" />
                        <RowDefinition Height="Auto" MinHeight="28" />
                        <RowDefinition Height="Auto" MinHeight="28" />
                        <RowDefinition Height="Auto" MinHeight="28" />
                        <RowDefinition Height="Auto" MinHeight="28" />
                        <RowDefinition Height="Auto" MinHeight="28" />
                        <RowDefinition Height="Auto" MinHeight="28" />
                        <RowDefinition Height="Auto" MinHeight="28" />
                        <RowDefinition Height="Auto" MinHeight="28" />
                        <RowDefinition Height="Auto" MinHeight="28" />
                        <RowDefinition Height="Auto" MinHeight="28" />
                        <RowDefinition Height="Auto" MinHeight="28" />
                    </Grid.RowDefinitions>
                    <Border
                        Grid.Row="0"
                        Grid.RowSpan="20"
                        Grid.Column="0"
                        Padding="14,12"
                        Background="White"
                        CornerRadius="8"
                        Visibility="{Binding HasMember0, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border.Effect>
                            <DropShadowEffect
                                BlurRadius="6"
                                Opacity="0.08"
                                ShadowDepth="1"
                                Color="#000000" />
                        </Border.Effect>
                    </Border>
                    <Border
                        Grid.Row="0"
                        Grid.RowSpan="20"
                        Grid.Column="0"
                        Background="White"
                        CornerRadius="8"
                        Visibility="{Binding Member0.IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <hc:CircleProgressBar
                            Width="40"
                            Height="40"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            ArcThickness="4"
                            Foreground="#4A90D9"
                            IsIndeterminate="True" />
                    </Border>
                    <Border
                        Grid.Row="1"
                        Grid.RowSpan="19"
                        Grid.Column="0"
                        Background="White"
                        CornerRadius="8"
                        Visibility="{Binding Member0.HasStatusError, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Foreground="#999999"
                            Text="{Binding Member0.StatusText}"
                            TextTrimming="CharacterEllipsis" />
                    </Border>
                    <Border
                        Grid.Row="0"
                        Grid.RowSpan="20"
                        Grid.Column="2"
                        Padding="14,12"
                        Background="White"
                        BorderBrush="#4A90D9"
                        BorderThickness="2"
                        CornerRadius="8"
                        Visibility="{Binding HasMember1, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border.Effect>
                            <DropShadowEffect
                                BlurRadius="6"
                                Opacity="0.08"
                                ShadowDepth="1"
                                Color="#000000" />
                        </Border.Effect>
                    </Border>
                    <Border
                        Grid.Row="0"
                        Grid.RowSpan="20"
                        Grid.Column="2"
                        Background="White"
                        CornerRadius="8"
                        Visibility="{Binding Member1.IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <hc:CircleProgressBar
                            Width="40"
                            Height="40"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            ArcThickness="4"
                            Foreground="#4A90D9"
                            IsIndeterminate="True" />
                    </Border>
                    <Border
                        Grid.Row="1"
                        Grid.RowSpan="19"
                        Grid.Column="2"
                        Background="White"
                        CornerRadius="8"
                        Visibility="{Binding Member1.HasStatusError, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Foreground="#999999"
                            Text="{Binding Member1.StatusText}"
                            TextTrimming="CharacterEllipsis" />
                    </Border>
                    <Border
                        Grid.Row="0"
                        Grid.RowSpan="20"
                        Grid.Column="4"
                        Padding="14,12"
                        Background="White"
                        CornerRadius="8"
                        Visibility="{Binding HasMember2, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border.Effect>
                            <DropShadowEffect
                                BlurRadius="6"
                                Opacity="0.08"
                                ShadowDepth="1"
                                Color="#000000" />
                        </Border.Effect>
                    </Border>
                    <Border
                        Grid.Row="0"
                        Grid.RowSpan="20"
                        Grid.Column="4"
                        Background="White"
                        CornerRadius="8"
                        Visibility="{Binding Member2.IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <hc:CircleProgressBar
                            Width="40"
                            Height="40"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            ArcThickness="4"
                            Foreground="#4A90D9"
                            IsIndeterminate="True" />
                    </Border>
                    <Border
                        Grid.Row="1"
                        Grid.RowSpan="19"
                        Grid.Column="4"
                        Background="White"
                        CornerRadius="8"
                        Visibility="{Binding Member2.HasStatusError, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Foreground="#999999"
                            Text="{Binding Member2.StatusText}"
                            TextTrimming="CharacterEllipsis" />
                    </Border>
                    <hc:SearchBar
                        Grid.Row="0"
                        Grid.Column="0"
                        Height="28"
                        Margin="12,2,12,8"
                        hc:InfoElement.Placeholder="{DynamicResource Search.Input}"
                        hc:TitleElement.Title="{DynamicResource Search.Title}"
                        hc:TitleElement.TitlePlacement="Left"
                        Command="{Binding Member0.SearchMemberCommand}"
                        Style="{StaticResource SearchBarExtend}"
                        Text="{Binding Member0.UserName, UpdateSourceTrigger=PropertyChanged}"
                        Visibility="{Binding HasMember0, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <hc:SearchBar
                        Grid.Row="0"
                        Grid.Column="2"
                        Height="28"
                        Margin="12,2,12,8"
                        hc:InfoElement.Placeholder="{DynamicResource Search.Input}"
                        hc:TitleElement.Title="{DynamicResource Search.Title}"
                        hc:TitleElement.TitlePlacement="Left"
                        Command="{Binding Member1.SearchMemberCommand}"
                        Style="{StaticResource SearchBarExtend}"
                        Text="{Binding Member1.UserName, UpdateSourceTrigger=PropertyChanged}"
                        Visibility="{Binding HasMember1, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <hc:SearchBar
                        Grid.Row="0"
                        Grid.Column="4"
                        Height="28"
                        Margin="12,2,12,8"
                        hc:InfoElement.Placeholder="{DynamicResource Search.Input}"
                        hc:TitleElement.Title="{DynamicResource Search.Title}"
                        hc:TitleElement.TitlePlacement="Left"
                        Command="{Binding Member2.SearchMemberCommand}"
                        Style="{StaticResource SearchBarExtend}"
                        Text="{Binding Member2.UserName, UpdateSourceTrigger=PropertyChanged}"
                        Visibility="{Binding HasMember2, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <Grid
                        Grid.Row="1"
                        Grid.Column="0"
                        Visibility="{Binding HasMember0, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <!--  Left: Avatar + Level + UID  -->
                        <StackPanel
                            Grid.Column="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                            <Border
                                Width="56"
                                Height="56"
                                BorderBrush="LightGray"
                                BorderThickness="1"
                                ClipToBounds="True"
                                CornerRadius="5">
                                <Image
                                    Width="56"
                                    Height="56"
                                    Source="{Binding Member0.AvatarUrl, IsAsync=True, Converter={StaticResource UrlToImageSourceConverter}}"
                                    Stretch="UniformToFill" />
                            </Border>
                            <TextBlock
                                Margin="0,4,0,0"
                                HorizontalAlignment="Center"
                                FontSize="11"
                                Foreground="Gray"
                                Text="{Binding Member0.Level}"
                                TextTrimming="CharacterEllipsis" />
                            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                <TextBlock
                                    FontSize="11"
                                    Foreground="Gray"
                                    TextTrimming="CharacterEllipsis"><Run Text="UID:" /><Run Text="{Binding Member0.UID}" /></TextBlock>
                                <Button
                                    Width="16"
                                    Height="16"
                                    Margin="4,0,0,0"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    ToolTip="Copy UID">
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="Click">
                                            <i:InvokeCommandAction Command="{Binding Member0.CopyUIDCommand}" />
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                    <Path
                                        Width="10"
                                        Height="10"
                                        Data="M16 1H4C2.9 1 2 1.9 2 3V17H4V3H16V1ZM19 5H8C6.9 5 6 5.9 6 7V21C6 22.1 6.9 23 8 23H19C20.1 23 21 22.1 21 21V7C21 5.9 20.1 5 19 5ZM19 21H8V7H19V21Z"
                                        Fill="#999999"
                                        Stretch="Uniform" />
                                </Button>
                            </StackPanel>
                        </StackPanel>
                        <!--  Right: Rank  -->
                        <StackPanel
                            Grid.Column="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                            <Border
                                Width="80"
                                Height="80"
                                BorderBrush="LightGray"
                                BorderThickness="1"
                                ClipToBounds="True"
                                CornerRadius="5">
                                <Image
                                    Width="80"
                                    Height="80"
                                    Source="{Binding Member0.RankIcon, IsAsync=True, Converter={StaticResource UrlToImageSourceConverter}}"
                                    Stretch="Uniform" />
                            </Border>
                            <StackPanel
                                Margin="0,4,0,0"
                                HorizontalAlignment="Center"
                                Orientation="Horizontal">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Text="{Binding Member0.PageRankName}"
                                    TextTrimming="CharacterEllipsis" />
                                <Image
                                    Width="14"
                                    Height="14"
                                    Margin="2,0,0,0"
                                    VerticalAlignment="Center"
                                    Source="pack://application:,,,/BlackGoldAncientSword.Resources;component/Images/star_icon.png"
                                    Visibility="{Binding Member0.PageHasStars, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Text="{Binding Member0.PageStarCount}"
                                    TextTrimming="CharacterEllipsis"
                                    Visibility="{Binding Member0.PageHasStars, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </StackPanel>
                            <TextBlock
                                Margin="0,2,0,0"
                                HorizontalAlignment="Center"
                                FontSize="12"
                                Foreground="Gray"
                                TextTrimming="CharacterEllipsis"><Run Text="{Binding Member0.RankTierScore, StringFormat={}{0}}" /><Run Text="{DynamicResource Stats.Points}" /></TextBlock>
                        </StackPanel>
                    </Grid>
                    <Grid
                        Grid.Row="1"
                        Grid.Column="2"
                        Visibility="{Binding HasMember1, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <!--  Left: Avatar + Level + UID  -->
                        <StackPanel
                            Grid.Column="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                            <Border
                                Width="56"
                                Height="56"
                                BorderBrush="LightGray"
                                BorderThickness="1"
                                ClipToBounds="True"
                                CornerRadius="5">
                                <Image
                                    Width="56"
                                    Height="56"
                                    Source="{Binding Member1.AvatarUrl, IsAsync=True, Converter={StaticResource UrlToImageSourceConverter}}"
                                    Stretch="UniformToFill" />
                            </Border>
                            <TextBlock
                                Margin="0,4,0,0"
                                HorizontalAlignment="Center"
                                FontSize="11"
                                Foreground="Gray"
                                Text="{Binding Member1.Level}"
                                TextTrimming="CharacterEllipsis" />
                            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                <TextBlock
                                    FontSize="11"
                                    Foreground="Gray"
                                    TextTrimming="CharacterEllipsis"><Run Text="UID:" /><Run Text="{Binding Member1.UID}" /></TextBlock>
                                <Button
                                    Width="16"
                                    Height="16"
                                    Margin="4,0,0,0"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    ToolTip="Copy UID">
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="Click">
                                            <i:InvokeCommandAction Command="{Binding Member1.CopyUIDCommand}" />
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                    <Path
                                        Width="10"
                                        Height="10"
                                        Data="M16 1H4C2.9 1 2 1.9 2 3V17H4V3H16V1ZM19 5H8C6.9 5 6 5.9 6 7V21C6 22.1 6.9 23 8 23H19C20.1 23 21 22.1 21 21V7C21 5.9 20.1 5 19 5ZM19 21H8V7H19V21Z"
                                        Fill="#999999"
                                        Stretch="Uniform" />
                                </Button>
                            </StackPanel>
                        </StackPanel>
                        <!--  Right: Rank  -->
                        <StackPanel
                            Grid.Column="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                            <Border
                                Width="80"
                                Height="80"
                                BorderBrush="LightGray"
                                BorderThickness="1"
                                ClipToBounds="True"
                                CornerRadius="5">
                                <Image
                                    Width="80"
                                    Height="80"
                                    Source="{Binding Member1.RankIcon, IsAsync=True, Converter={StaticResource UrlToImageSourceConverter}}"
                                    Stretch="Uniform" />
                            </Border>
                            <StackPanel
                                Margin="0,4,0,0"
                                HorizontalAlignment="Center"
                                Orientation="Horizontal">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Text="{Binding Member1.PageRankName}"
                                    TextTrimming="CharacterEllipsis" />
                                <Image
                                    Width="14"
                                    Height="14"
                                    Margin="2,0,0,0"
                                    VerticalAlignment="Center"
                                    Source="pack://application:,,,/BlackGoldAncientSword.Resources;component/Images/star_icon.png"
                                    Visibility="{Binding Member1.PageHasStars, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Text="{Binding Member1.PageStarCount}"
                                    TextTrimming="CharacterEllipsis"
                                    Visibility="{Binding Member1.PageHasStars, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </StackPanel>
                            <TextBlock
                                Margin="0,2,0,0"
                                HorizontalAlignment="Center"
                                FontSize="12"
                                Foreground="Gray"
                                TextTrimming="CharacterEllipsis"><Run Text="{Binding Member1.RankTierScore, StringFormat={}{0}}" /><Run Text="{DynamicResource Stats.Points}" /></TextBlock>
                        </StackPanel>
                    </Grid>
                    <Grid
                        Grid.Row="1"
                        Grid.Column="4"
                        Visibility="{Binding HasMember2, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <!--  Left: Avatar + Level + UID  -->
                        <StackPanel
                            Grid.Column="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                            <Border
                                Width="56"
                                Height="56"
                                BorderBrush="LightGray"
                                BorderThickness="1"
                                ClipToBounds="True"
                                CornerRadius="5">
                                <Image
                                    Width="56"
                                    Height="56"
                                    Source="{Binding Member2.AvatarUrl, IsAsync=True, Converter={StaticResource UrlToImageSourceConverter}}"
                                    Stretch="UniformToFill" />
                            </Border>
                            <TextBlock
                                Margin="0,4,0,0"
                                HorizontalAlignment="Center"
                                FontSize="11"
                                Foreground="Gray"
                                Text="{Binding Member2.Level}"
                                TextTrimming="CharacterEllipsis" />
                            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                <TextBlock
                                    FontSize="11"
                                    Foreground="Gray"
                                    TextTrimming="CharacterEllipsis"><Run Text="UID:" /><Run Text="{Binding Member2.UID}" /></TextBlock>
                                <Button
                                    Width="16"
                                    Height="16"
                                    Margin="4,0,0,0"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    ToolTip="Copy UID">
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="Click">
                                            <i:InvokeCommandAction Command="{Binding Member2.CopyUIDCommand}" />
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                    <Path
                                        Width="10"
                                        Height="10"
                                        Data="M16 1H4C2.9 1 2 1.9 2 3V17H4V3H16V1ZM19 5H8C6.9 5 6 5.9 6 7V21C6 22.1 6.9 23 8 23H19C20.1 23 21 22.1 21 21V7C21 5.9 20.1 5 19 5ZM19 21H8V7H19V21Z"
                                        Fill="#999999"
                                        Stretch="Uniform" />
                                </Button>
                            </StackPanel>
                        </StackPanel>
                        <!--  Right: Rank  -->
                        <StackPanel
                            Grid.Column="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                            <Border
                                Width="80"
                                Height="80"
                                BorderBrush="LightGray"
                                BorderThickness="1"
                                ClipToBounds="True"
                                CornerRadius="5">
                                <Image
                                    Width="80"
                                    Height="80"
                                    Source="{Binding Member2.RankIcon, IsAsync=True, Converter={StaticResource UrlToImageSourceConverter}}"
                                    Stretch="Uniform" />
                            </Border>
                            <StackPanel
                                Margin="0,4,0,0"
                                HorizontalAlignment="Center"
                                Orientation="Horizontal">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Text="{Binding Member2.PageRankName}"
                                    TextTrimming="CharacterEllipsis" />
                                <Image
                                    Width="14"
                                    Height="14"
                                    Margin="2,0,0,0"
                                    VerticalAlignment="Center"
                                    Source="pack://application:,,,/BlackGoldAncientSword.Resources;component/Images/star_icon.png"
                                    Visibility="{Binding Member2.PageHasStars, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Text="{Binding Member2.PageStarCount}"
                                    TextTrimming="CharacterEllipsis"
                                    Visibility="{Binding Member2.PageHasStars, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </StackPanel>
                            <TextBlock
                                Margin="0,2,0,0"
                                HorizontalAlignment="Center"
                                FontSize="12"
                                Foreground="Gray"
                                TextTrimming="CharacterEllipsis"><Run Text="{Binding Member2.RankTierScore, StringFormat={}{0}}" /><Run Text="{DynamicResource Stats.Points}" /></TextBlock>
                        </StackPanel>
                    </Grid>
                    <Border
                        Grid.Row="2"
                        Grid.Column="0"
                        Height="1"
                        Margin="14,6,14,6"
                        Background="#E8E8E8"
