<bases:UserControlBase
    x:Class="BlackGoldAncientSword.Modules.UI.Home.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:bases="clr-namespace:BlackGoldAncientSword.Framework.Core.Bases.Views;assembly=BlackGoldAncientSword.Framework"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="clr-namespace:BlackGoldAncientSword.Modules.UI.Home.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewmodels:HomePageViewModel}"
    d:DesignHeight="600"
    d:DesignWidth="960"
    FontFamily="Segoe UI"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  ===== RunningBlock 滚动条 =====  -->
        <hc:RunningBlock
            Grid.Row="0"
            Height="4"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top" />

        <!--  ===== 状态提示文字 =====  -->
        <StackPanel
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

            <!--  循环等待指示器  -->
            <Border
                HorizontalAlignment="Center"
                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                <hc:CircleProgressBar
                    Width="64"
                    Height="64"
                    ArcThickness="4"
                    Foreground="#4A90D9"
                    IsIndeterminate="True" />
            </Border>

            <TextBlock
                FontSize="18"
                FontWeight="SemiBold"
                Foreground="#555555"
                HorizontalAlignment="Center"
                Text="{Binding StatusText}" />
            <TextBlock
                Margin="0,12,0,0"
                FontSize="13"
                Foreground="#999999"
                HorizontalAlignment="Center"
                Text="{Binding StatusHint}" />
        </StackPanel>
    </Grid>
</bases:UserControlBase>
