<Window
    x:Class="NarakaBladepoint.StatsAssistant.App.Shell.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:chrome="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    xmlns:consts="clr-namespace:NarakaBladepoint.StatsAssistant.Framework.Core.Consts;assembly=NarakaBladepoint.StatsAssistant.Framework"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:shell="clr-namespace:NarakaBladepoint.StatsAssistant.App.Shell"
    Title="{DynamicResource App.Title}"
    Width="1080"
    Height="761"
    d:DataContext="{d:DesignInstance Type=shell:MainWindowViewModel}"
    d:Icon="/NarakaBladepoint.StatsAssistant.Resources;component/Images/app.ico"
    d:Title="{DynamicResource App.Title}"
    prism:ViewModelLocator.AutoWireViewModel="True"
    AllowsTransparency="True"
    Background="Transparent"
    Icon="/NarakaBladepoint.StatsAssistant.Resources;component/Images/app.ico"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">
    <chrome:WindowChrome.WindowChrome>
        <chrome:WindowChrome
            CaptionHeight="0"
            CornerRadius="10"
            GlassFrameThickness="0"
            ResizeBorderThickness="4" />
    </chrome:WindowChrome.WindowChrome>

    <Border
        Background="#F5F5F5"
        ClipToBounds="True"
        CornerRadius="5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  ==================== Row 0: Title bar ====================  -->

            <!--  Title bar background  -->
            <Border Grid.Row="0" Background="#F5F5F5" />

            <!--  Window icon + title  -->
            <StackPanel
                Grid.Row="0"
                Margin="25,0,0,0"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <Button
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0"
                    Command="{Binding GoBackCommand}"
                    Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Opacity" Value="1" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CanGoBack}" Value="False">
                                    <Setter Property="Opacity" Value="0.5" />
                                    <Setter Property="IsEnabled" Value="False" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Image
                        Width="15"
                        Height="15"
                        Source="/NarakaBladepoint.StatsAssistant.Resources;component/Images/back.png"
                        Stretch="Uniform" />
                </Button>
                <Image
                    Width="25"
                    Margin="20,0,0,0"
                    Source="{Binding Icon, RelativeSource={RelativeSource AncestorType=Window}}"
                    Stretch="Uniform" />
                <TextBlock
                    Margin="6,0,0,0"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Foreground="#333333"
                    Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}" />
            </StackPanel>

            <!--  Custom title bar buttons  -->
            <StackPanel
                Grid.Row="0"
                Margin="0,0,5,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Panel.ZIndex="9999"
                Orientation="Horizontal">
                <Button
                    Width="28"
                    Height="24"
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="MinimizeButton_Click"
                    Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="ToolTip" Value="{DynamicResource TitleBar.Minimize}" />
                        </Style>
                    </Button.Style>
                    <Image
                        Width="16"
                        Height="16"
                        Source="/NarakaBladepoint.StatsAssistant.Resources;component/Images/minimize.png"
                        Stretch="Uniform" />
                </Button>
                <Button
                    Width="28"
                    Height="24"
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="MaximizeButton_Click"
                    Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="ToolTip" Value="{DynamicResource TitleBar.Maximize}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                                    <Setter Property="ToolTip" Value="{DynamicResource TitleBar.Restore}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Image
                        Width="16"
                        Height="16"
                        Source="/NarakaBladepoint.StatsAssistant.Resources;component/Images/maximize.png"
                        Stretch="Uniform" />
                </Button>
                <Button
                    Width="28"
                    Height="24"
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="CloseButton_Click"
                    Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="ToolTip" Value="{DynamicResource TitleBar.Close}" />
                        </Style>
                    </Button.Style>
                    <Image
                        Width="16"
                        Height="16"
                        Source="/NarakaBladepoint.StatsAssistant.Resources;component/Images/close.png"
                        Stretch="Uniform" />
                </Button>
            </StackPanel>

            <!--  ==================== Row 1: Content area ====================  -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100" MinWidth="100" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--  Left sidebar  -->
                <Border
                    Grid.Column="0"
                    Margin="0,10,0,0"
                    Padding="0"
                    Background="#F5F5F5"
                    ClipToBounds="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <!--  Home  -->
                            <Button Command="{Binding NavigateToHomeCommand}" ToolTip="{DynamicResource Nav.Home}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Height" Value="30" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="3,0,0,0" />
                                        <Setter Property="BorderBrush" Value="Transparent" />
                                        <Setter Property="Cursor" Value="Hand" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActivePage}" Value="HomePage">
                                                <Setter Property="Background" Value="#E0E8F0" />
                                                <Setter Property="BorderBrush" Value="#4A90D9" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Image
                                        Grid.Column="0"
                                        Width="20"
                                        Height="20"
                                        Margin="20,0,0,0"
                                        VerticalAlignment="Center"
                                        Source="/NarakaBladepoint.StatsAssistant.Resources;component/Images/home.png"
                                        Stretch="Uniform" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        FontSize="13"
                                        Text="{DynamicResource Nav.Home}"
                                        TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Button>

                            <!--  Stats  -->
                            <Button Command="{Binding NavigateToStatsCommand}" ToolTip="{DynamicResource Nav.Stats}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Height" Value="30" />
                                        <Setter Property="Margin" Value="0,0,0,0" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="3,0,0,0" />
                                        <Setter Property="BorderBrush" Value="Transparent" />
                                        <Setter Property="Cursor" Value="Hand" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActivePage}" Value="StatsPage">
                                                <Setter Property="Background" Value="#E0E8F0" />
                                                <Setter Property="BorderBrush" Value="#4A90D9" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Image
                                        Grid.Column="0"
                                        Width="20"
                                        Height="20"
                                        Margin="20,0,0,0"
                                        VerticalAlignment="Center"
                                        Source="/NarakaBladepoint.StatsAssistant.Resources;component/Images/stats.png"
                                        Stretch="Uniform" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        FontSize="13"
                                        Text="{DynamicResource Nav.Stats}"
                                        TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Button>

                            <!--  Search  -->
                            <Button Command="{Binding NavigateToSearchCommand}" ToolTip="{DynamicResource Nav.Search}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Height" Value="30" />
                                        <Setter Property="Margin" Value="0,0,0,0" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="3,0,0,0" />
                                        <Setter Property="BorderBrush" Value="Transparent" />
                                        <Setter Property="Cursor" Value="Hand" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActivePage}" Value="SearchPage">
                                                <Setter Property="Background" Value="#E0E8F0" />
                                                <Setter Property="BorderBrush" Value="#4A90D9" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Image
                                        Grid.Column="0"
                                        Width="20"
                                        Height="20"
                                        Margin="20,0,0,0"
                                        VerticalAlignment="Center"
                                        Source="/NarakaBladepoint.StatsAssistant.Resources;component/Images/search.png"
                                        Stretch="Uniform" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        FontSize="13"
                                        Text="{DynamicResource Nav.Search}"
                                        TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Button>
                        </StackPanel>

                        <!--  Bottom: Feedback, Announcement, Settings  -->
                        <StackPanel
                            Grid.Row="1"
                            Margin="0,0,0,12"
                            VerticalAlignment="Bottom">

                            <!--  Feedback (Issue)  -->
                            <Button Command="{Binding OpenFeedbackCommand}" ToolTip="{DynamicResource Nav.Feedback}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Height" Value="30" />
                                        <Setter Property="Margin" Value="0,0,0,0" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="3,0,0,0" />
                                        <Setter Property="BorderBrush" Value="Transparent" />
                                        <Setter Property="Cursor" Value="Hand" />
                                    </Style>
                                </Button.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Image
                                        Grid.Column="0"
                                        Width="20"
                                        Height="20"
                                        Margin="20,0,0,0"
                                        VerticalAlignment="Center"
                                        Source="/NarakaBladepoint.StatsAssistant.Resources;component/Images/feedback.png"
                                        Stretch="Uniform" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        FontSize="13"
                                        Text="{DynamicResource Nav.Feedback}"
                                        TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Button>

                            <!--  Announcement  -->
                            <Button Command="{Binding NavigateToAnnouncementCommand}" ToolTip="{DynamicResource Nav.Announcement}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Height" Value="30" />
                                        <Setter Property="Margin" Value="0,0,0,0" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="3,0,0,0" />
                                        <Setter Property="BorderBrush" Value="Transparent" />
                                        <Setter Property="Cursor" Value="Hand" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActivePage}" Value="AnnouncementPage">
                                                <Setter Property="Background" Value="#E0E8F0" />
                                                <Setter Property="BorderBrush" Value="#4A90D9" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Image
                                        Grid.Column="0"
                                        Width="20"
                                        Height="20"
                                        Margin="20,0,0,0"
                                        VerticalAlignment="Center"
                                        Source="/NarakaBladepoint.StatsAssistant.Resources;component/Images/announcement.png"
                                        Stretch="Uniform" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        FontSize="13"
                                        Text="{DynamicResource Nav.Announcement}"
                                        TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Button>

                            <Button Command="{Binding OpenSettingsCommand}" ToolTip="{DynamicResource Nav.Settings}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Height" Value="30" />
                                        <Setter Property="Margin" Value="0,0,0,0" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="3,0,0,0" />
                                        <Setter Property="BorderBrush" Value="Transparent" />
                                        <Setter Property="Cursor" Value="Hand" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActivePage}" Value="SettingsPage">
                                                <Setter Property="Background" Value="#E0E8F0" />
                                                <Setter Property="BorderBrush" Value="#4A90D9" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Image
                                        Grid.Column="0"
                                        Width="20"
                                        Height="20"
                                        Margin="20,0,0,0"
                                        VerticalAlignment="Center"
                                        Source="/NarakaBladepoint.StatsAssistant.Resources;component/Images/settings.png"
                                        Stretch="Uniform" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        FontSize="13"
                                        Text="{DynamicResource Nav.Settings}"
                                        TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!--  Grid splitter  -->
                <GridSplitter
                    Grid.Column="1"
                    Width="4"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Stretch"
                    Background="Transparent"
                    ShowsPreview="True"
                    Style="{StaticResource ToolBarThumbHorizontalStyle}" />

                <!--  Right content area  -->
                <Grid Grid.Column="2">
                    <ContentControl prism:RegionManager.RegionName="{x:Static consts:GlobalConstant.MainContentRegion}" />
                </Grid>
            </Grid>

            <!--  ==================== Overlays (span all rows) ====================  -->

            <!--  Announcement overlay (covers entire window, below toast)  -->
            <ContentControl
                Grid.RowSpan="2"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch"
                Panel.ZIndex="900"
                prism:RegionManager.RegionName="{x:Static consts:GlobalConstant.AnnouncementRegion}" />
            <!--  Close prompt overlay (covers entire window, above announcement)  -->
            <ContentControl
                Grid.RowSpan="2"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch"
                Panel.ZIndex="950"
                prism:RegionManager.RegionName="{x:Static consts:GlobalConstant.ClosePromptRegion}" />

            <!--  Stacked toast notifications (topmost)  -->
            <ItemsControl
                Grid.RowSpan="2"
                Margin="0,60,0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Panel.ZIndex="999"
                IsHitTestVisible="False"
                ItemsSource="{Binding ToastItems}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border
                            x:Name="ToastItemBorder"
                            MaxWidth="500"
                            Margin="0,0,0,8"
                            Padding="16,10"
                            Background="#4CAF50"
                            BorderBrush="#388E3C"
                            BorderThickness="1"
                            CornerRadius="8"
                            Loaded="ToastItemBorder_Loaded"
                            Opacity="0"
                            RenderTransformOrigin="0.5,0">
                            <Border.RenderTransform>
                                <TranslateTransform Y="-40" />
                            </Border.RenderTransform>
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="14"
                                Foreground="White"
                                Text="{Binding Message}"
                                TextWrapping="Wrap" />
                        </Border>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsError}" Value="True">
                                <Setter TargetName="ToastItemBorder" Property="Background" Value="#F44336" />
                                <Setter TargetName="ToastItemBorder" Property="BorderBrush" Value="#D32F2F" />
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Border>
</Window>
