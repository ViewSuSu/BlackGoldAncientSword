# Auto detect text files and perform LF normalization
* text=auto

# Source code
*.cs          text eol=crlf diff=csharp
*.xaml        text eol=crlf
*.xaml.cs     text eol=crlf diff=csharp
*.xml         text eol=crlf
*.json        text eol=crlf
*.config      text eol=crlf
*.props       text eol=crlf
*.targets     text eol=crlf
*.sln         text eol=crlf
*.csproj      text eol=crlf

# Scripts
*.ps1         text eol=crlf
*.cmd         text eol=crlf
*.bat         text eol=crlf
*.sh          text eol=lf

# YAML / CI
*.yml         text eol=lf
*.yaml        text eol=lf
*.md          text eol=crlf

# Images - binary
*.png         binary
*.jpg         binary
*.jpeg        binary
*.gif         binary
*.ico         binary
*.bmp         binary

# Archives
*.zip         binary
*.7z          binary

# Certificates
*.pfx         binary
*.snk         binary